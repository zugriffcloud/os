{
  "name": "@zugriff/preset-react-router",
  "version": "1.0.2",
  "description": "Deploy your React Router application with zugriff",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zugriffcloud/os.git"
  },
  "types": "./dist/index.d.ts",
  "module": "./dist/index.mjs",
  "main": "./dist/index.cjs",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./entry.server.tsx": "./dist/entry.server.tsx",
    "./entry.server.jsx": "./dist/entry.server.jsx",
    "./README.md": "./README.md",
    "./LICENSE": "./LICENSE"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf ./dist && rollup -c --bundleConfigAsCjs && cp ./lib/entry.server.tsx ./dist/entry.server.tsx",
    "test": "vitest run"
  },
  "keywords": [
    "preset",
    "react",
    "remix",
    "react-router",
    "reactrouter",
    "react router",
    "zugriff",
    "edge",
    "runtime"
  ],
  "author": "Luca Goslar <luca@zugriff.eu>",
  "license": "MIT",
  "dependencies": {
    "@react-router/dev": "^7.14.0",
    "esbuild": "^0.28.0"
  },
  "peerDependencies": {
    "react-router": ">= 7.9.0",
    "react": ">= 18 < 20",
    "react-dom": ">= 18 < 20",
    "vite": ">= 5.0.0"
  }
}
